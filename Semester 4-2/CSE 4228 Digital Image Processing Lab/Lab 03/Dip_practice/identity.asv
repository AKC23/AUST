
I = imread('cameraman.png'); 
O=I;

[row,col]=size(I);

K=zeros(1,256);

for i=1:row
    for j=1:col
        temp=I(i,j)+1;
        K(temp)=K(temp)+1;
        
    end    
end

subplot(1, 4, 1);
imshow(I);
title('Original Image');

subplot(1,4,2);
bar(K);


subplot(1, 4, 3);
imshow(O);
title('Transformed Image');


